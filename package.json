{
  "name": "ghostflow",
  "displayName": "Ghostflow",
  "description": "Ghostflow Developer-Native Security Architecture Visualizer",
  "version": "0.1.0",
  "publisher": "cchoiyon",
  "repository": {
    "type": "git",
    "url": "https://github.com/cchoiyon/Ghostflow.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghostflow.scan",
        "title": "Ghostflow: Scan Active File",
        "icon": "$(play)"
      },
      {
        "command": "ghostflow.scanWorkspace",
        "title": "Ghostflow: Scan Entire Workspace",
        "icon": "$(repo-sync)"
      },
      {
        "command": "ghostflow.exportReport",
        "title": "Ghostflow: Export HTML Audit Report",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ghostflow.scan",
          "when": "view == ghostflow.visualizerView || view == ghostflow.threatReport",
          "group": "navigation@1"
        },
        {
          "command": "ghostflow.scanWorkspace",
          "when": "view == ghostflow.visualizerView || view == ghostflow.threatReport",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ghostflow-sidebar",
          "title": "Ghostflow",
          "icon": "media/ghostflow-icon.svg"
        }
      ]
    },
    "views": {
      "ghostflow-sidebar": [
        {
          "type": "webview",
          "id": "ghostflow.visualizerView",
          "name": "Architecture Map",
          "icon": "media/ghostflow-icon.svg"
        },
        {
          "type": "webview",
          "id": "ghostflow.threatReport",
          "name": "Threat Report",
          "icon": "media/ghostflow-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
